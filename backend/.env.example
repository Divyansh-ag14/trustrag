# Database
DATABASE_URL=postgresql+asyncpg://trustrag:trustrag_dev@localhost:5435/trustrag
DATABASE_SYNC_URL=postgresql://trustrag:trustrag_dev@localhost:5435/trustrag

# Vector store
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Cache
REDIS_URL=redis://localhost:6379/0

# API keys
OPENAI_API_KEY=sk-your-key-here
COHERE_API_KEY=your-cohere-key-here

# Auth
JWT_SECRET=change-me-in-production-use-a-long-random-string

# Environment
ENVIRONMENT=development
DEBUG=true

# Model config
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
RERANK_MODEL=rerank-v3.5

# RAG tuning
CHUNK_SIZE=512
CHUNK_OVERLAP=50
CONTEXT_TOKEN_BUDGET=4000
RETRIEVAL_TOP_K=50
RERANK_TOP_K=10

# Upload limits
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=uploads

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
